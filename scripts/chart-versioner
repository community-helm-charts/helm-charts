#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { existsSync, readFileSync, writeFileSync } from "node:fs";
import { extname, join } from "node:path";
import process from "node:process";

const VERSION_RE = /^version:\s*['"]?([^'"\s#]+)['"]?\s*(?:#.*)?$/m;
const SEMVER_RE = /^(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$/;
const TYPE_RE = /^(?<type>[a-zA-Z]+)(?:\([^)]+\))?(?<breaking>!)?:/;
const BUMP_ORDER = { patch: 1, minor: 2, major: 3 };

class ChartVersionerError extends Error {}

function git(args, cwd) {
  const result = gitMaybe(args, cwd);
  if (result.status !== 0) {
    throw new ChartVersionerError(result.stderr.trim() || `git ${args.join(" ")} failed`);
  }
  return result.stdout;
}

function gitMaybe(args, cwd) {
  return spawnSync("git", args, {
    cwd,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
  });
}

function isZeroSha(value) {
  return Boolean(value) && new Set(value).size === 1 && value[0] === "0";
}

function resolveBase(base, head, cwd) {
  if (base && !isZeroSha(base)) {
    const result = gitMaybe(["rev-parse", "--verify", `${base}^{commit}`], cwd);
    if (result.status === 0) {
      return base;
    }
  }

  const parent = gitMaybe(["rev-parse", "--verify", `${head}^{commit}^`], cwd);
  if (parent.status === 0) {
    return `${head}^`;
  }

  return git(["hash-object", "-t", "tree", "/dev/null"], cwd).trim();
}

function changedFiles(base, head, cwd) {
  const output = git(["diff", "--name-only", "--diff-filter=ACMRT", `${base}..${head}`], cwd);
  return output
    .split("\n")
    .map((line) => line.trim())
    .filter(Boolean);
}

function chartNameFromPath(path, chartsDir) {
  const parts = path.split("/");
  if (parts.length < 3 || parts[0] !== chartsDir) {
    return null;
  }
  return parts[1];
}

function isReleaseRelevant(path) {
  return extname(path).toLowerCase() !== ".md";
}

function chartVersionFromText(text, source) {
  const match = VERSION_RE.exec(text);
  if (!match) {
    throw new ChartVersionerError(`Could not find root version in ${source}`);
  }
  return match[1];
}

function readWorktreeChartVersion(chartPath) {
  const chartYaml = join(chartPath, "Chart.yaml");
  return chartVersionFromText(readFileSync(chartYaml, "utf8"), chartYaml);
}

function readRefChartVersion(ref, chartYamlPath, cwd) {
  const result = gitMaybe(["show", `${ref}:${chartYamlPath}`], cwd);
  if (result.status !== 0) {
    return null;
  }
  return chartVersionFromText(result.stdout, `${ref}:${chartYamlPath}`);
}

function bumpVersion(version, bump) {
  const match = SEMVER_RE.exec(version);
  if (!match) {
    throw new ChartVersionerError(`Only numeric semver versions are supported, got ${JSON.stringify(version)}`);
  }

  const [, majorText, minorText, patchText] = match;
  const major = Number(majorText);
  const minor = Number(minorText);
  const patch = Number(patchText);

  if (bump === "major") {
    return `${major + 1}.0.0`;
  }
  if (bump === "minor") {
    return `${major}.${minor + 1}.0`;
  }
  if (bump === "patch") {
    return `${major}.${minor}.${patch + 1}`;
  }
  throw new ChartVersionerError(`Unknown bump type ${JSON.stringify(bump)}`);
}

function commitMessagesForChart(base, head, chart, chartsDir, cwd) {
  const output = git(["log", "--format=%B%x00", `${base}..${head}`, "--", `${chartsDir}/${chart}`], cwd);
  return output
    .split("\0")
    .map((message) => message.trim())
    .filter(Boolean);
}

function maxBump(current, candidate) {
  if (!current) {
    return candidate;
  }
  return BUMP_ORDER[current] >= BUMP_ORDER[candidate] ? current : candidate;
}

function bumpFromMessages(messages) {
  let selected = null;
  for (const message of messages) {
    const firstLine = message.split(/\r?\n/, 1)[0] || "";
    const typeMatch = TYPE_RE.exec(firstLine);
    if (!typeMatch) {
      continue;
    }

    const commitType = typeMatch.groups.type;
    if (commitType !== "feat" && commitType !== "fix") {
      continue;
    }

    if (typeMatch.groups.breaking) {
      selected = "major";
    } else if (commitType === "feat") {
      selected = maxBump(selected, "minor");
    } else if (commitType === "fix") {
      selected = maxBump(selected, "patch");
    }
  }
  return selected;
}

function replaceWorktreeVersion(chartPath, nextVersion) {
  const chartYaml = join(chartPath, "Chart.yaml");
  const text = readFileSync(chartYaml, "utf8");
  let count = 0;
  const newText = text.replace(/^version:\s*.*$/m, () => {
    count += 1;
    return `version: ${nextVersion}`;
  });

  if (count !== 1) {
    throw new ChartVersionerError(`Could not update root version in ${chartYaml}`);
  }
  writeFileSync(chartYaml, newText, "utf8");
}

function buildPlan(base, head, chartsDir, cwd) {
  const files = changedFiles(base, head, cwd);
  const filesByChart = new Map();
  for (const path of files) {
    const chart = chartNameFromPath(path, chartsDir);
    if (!chart || !isReleaseRelevant(path)) {
      continue;
    }
    if (!filesByChart.has(chart)) {
      filesByChart.set(chart, []);
    }
    filesByChart.get(chart).push(path);
  }

  const chartPlans = [];
  for (const chart of [...filesByChart.keys()].sort()) {
    const chartPath = join(cwd, chartsDir, chart);
    const chartYamlPath = `${chartsDir}/${chart}/Chart.yaml`;
    if (!existsSync(join(chartPath, "Chart.yaml"))) {
      continue;
    }

    const currentVersion = readWorktreeChartVersion(chartPath);
    const baseVersion = readRefChartVersion(base, chartYamlPath, cwd);
    const messages = commitMessagesForChart(base, head, chart, chartsDir, cwd);
    const bump = bumpFromMessages(messages);
    if (!bump) {
      continue;
    }

    if (baseVersion === null) {
      chartPlans.push({
        name: chart,
        path: `${chartsDir}/${chart}`,
        files: filesByChart.get(chart),
        bump: "new",
        base_version: null,
        current_version: currentVersion,
        next_version: currentVersion,
        needs_update: false,
      });
      continue;
    }

    const nextVersion = bumpVersion(baseVersion, bump);
    if (currentVersion !== baseVersion && currentVersion !== nextVersion) {
      throw new ChartVersionerError(
        `Chart ${chart} has version ${currentVersion}, expected ${baseVersion} or ${nextVersion}`,
      );
    }

    chartPlans.push({
      name: chart,
      path: `${chartsDir}/${chart}`,
      files: filesByChart.get(chart),
      bump,
      base_version: baseVersion,
      current_version: currentVersion,
      next_version: nextVersion,
      needs_update: currentVersion !== nextVersion,
    });
  }

  return {
    base,
    head,
    changed_charts: chartPlans.map((chart) => chart.name),
    charts: chartPlans,
  };
}

function writeGithubOutput(path, plan) {
  if (!path) {
    return;
  }
  const changed = plan.changed_charts.join(",");
  const lines = [`has_changes=${changed ? "true" : "false"}`, `changed_charts=${changed}`];
  writeFileSync(path, `${lines.join("\n")}\n`, { encoding: "utf8", flag: "a" });
}

function writeOutput(path, plan) {
  if (!path) {
    return;
  }
  writeFileSync(path, `${JSON.stringify(plan, null, 2)}\n`, "utf8");
}

function printPlan(plan) {
  console.log(JSON.stringify(plan, null, 2));
}

function cmdPlan(args) {
  const cwd = process.cwd();
  const base = resolveBase(args.base, args.head, cwd);
  const plan = buildPlan(base, args.head, args.chartsDir, cwd);
  writeOutput(args.output, plan);
  writeGithubOutput(args.githubOutput, plan);
  printPlan(plan);
}

function cmdWrite(args) {
  const cwd = process.cwd();
  const base = resolveBase(args.base, args.head, cwd);
  const plan = buildPlan(base, args.head, args.chartsDir, cwd);
  for (const chart of plan.charts) {
    if (chart.needs_update) {
      replaceWorktreeVersion(join(cwd, chart.path), chart.next_version);
      chart.updated = true;
    } else {
      chart.updated = false;
    }
  }

  writeOutput(args.output, plan);
  writeGithubOutput(args.githubOutput, plan);

  if (plan.charts.length === 0) {
    console.log("No changed charts detected.");
    return;
  }
  for (const chart of plan.charts) {
    const action = chart.updated ? "updated" : "unchanged";
    console.log(`${chart.name}: ${chart.base_version || "new"} -> ${chart.next_version} (${chart.bump}, ${action})`);
  }
}

function cmdCheck(args) {
  const cwd = process.cwd();
  const base = resolveBase(args.base, args.head, cwd);
  const plan = buildPlan(base, args.head, args.chartsDir, cwd);
  writeOutput(args.output, plan);
  writeGithubOutput(args.githubOutput, plan);
  const stale = plan.charts.filter((chart) => chart.needs_update);
  if (stale.length > 0) {
    for (const chart of stale) {
      console.error(`${chart.name} requires version ${chart.next_version} (${chart.bump} from ${chart.base_version})`);
    }
    throw new ChartVersionerError("Chart versions are not up to date");
  }
  printPlan(plan);
}

function parseArgs(argv) {
  const [command, ...rest] = argv;
  if (!command || !["plan", "write", "check"].includes(command)) {
    throw new ChartVersionerError("Usage: chart-versioner <plan|write|check> [--base REF] [--head REF]");
  }

  const args = {
    base: process.env.CHART_VERSIONER_BASE || "HEAD~1",
    chartsDir: "charts",
    command,
    githubOutput: undefined,
    head: process.env.CHART_VERSIONER_HEAD || "HEAD",
    output: undefined,
  };

  for (let i = 0; i < rest.length; i += 1) {
    const option = rest[i];
    const value = rest[i + 1];
    if (!option.startsWith("--")) {
      throw new ChartVersionerError(`Unexpected argument ${JSON.stringify(option)}`);
    }
    if (value === undefined || value.startsWith("--")) {
      throw new ChartVersionerError(`Missing value for ${option}`);
    }

    if (option === "--base") {
      args.base = value;
    } else if (option === "--head") {
      args.head = value;
    } else if (option === "--charts-dir") {
      args.chartsDir = value;
    } else if (option === "--output") {
      args.output = value;
    } else if (option === "--github-output") {
      args.githubOutput = value;
    } else {
      throw new ChartVersionerError(`Unknown option ${option}`);
    }
    i += 1;
  }

  return args;
}

function main() {
  try {
    const args = parseArgs(process.argv.slice(2));
    if (args.command === "plan") {
      cmdPlan(args);
    } else if (args.command === "write") {
      cmdWrite(args);
    } else if (args.command === "check") {
      cmdCheck(args);
    }
    return 0;
  } catch (error) {
    if (error instanceof ChartVersionerError) {
      console.error(`error: ${error.message}`);
      return 1;
    }
    throw error;
  }
}

process.exitCode = main();
