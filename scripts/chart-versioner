#!/usr/bin/env python3
import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path


VERSION_RE = re.compile(r"^version:\s*['\"]?([^'\"\s#]+)['\"]?\s*(?:#.*)?$", re.MULTILINE)
SEMVER_RE = re.compile(r"^(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$")
TYPE_RE = re.compile(r"^(?P<type>[a-zA-Z]+)(?:\([^)]+\))?(?P<breaking>!)?:")
BUMP_ORDER = {"patch": 1, "minor": 2, "major": 3}


class ChartVersionerError(Exception):
    pass


def git(args, cwd):
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        raise ChartVersionerError(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result.stdout


def git_maybe(args, cwd):
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return result


def is_zero_sha(value):
    return value and set(value) == {"0"}


def resolve_base(base, head, cwd):
    if base and not is_zero_sha(base):
        result = git_maybe(["rev-parse", "--verify", f"{base}^{{commit}}"], cwd)
        if result.returncode == 0:
            return base

    result = git_maybe(["rev-parse", "--verify", f"{head}^{{commit}}^"], cwd)
    if result.returncode == 0:
        return f"{head}^"

    return git(["hash-object", "-t", "tree", "/dev/null"], cwd).strip()


def changed_files(base, head, cwd):
    output = git(["diff", "--name-only", "--diff-filter=ACMRT", f"{base}..{head}"], cwd)
    return [line.strip() for line in output.splitlines() if line.strip()]


def chart_name_from_path(path, charts_dir):
    parts = Path(path).parts
    if len(parts) < 3 or parts[0] != charts_dir:
        return None
    return parts[1]


def is_release_relevant(path):
    return Path(path).suffix.lower() != ".md"


def chart_version_from_text(text, source):
    match = VERSION_RE.search(text)
    if not match:
        raise ChartVersionerError(f"Could not find root version in {source}")
    return match.group(1)


def read_worktree_chart_version(chart_path):
    chart_yaml = chart_path / "Chart.yaml"
    return chart_version_from_text(chart_yaml.read_text(encoding="utf-8"), str(chart_yaml))


def read_ref_chart_version(ref, chart_yaml_path, cwd):
    result = git_maybe(["show", f"{ref}:{chart_yaml_path}"], cwd)
    if result.returncode != 0:
        return None
    return chart_version_from_text(result.stdout, f"{ref}:{chart_yaml_path}")


def bump_version(version, bump):
    match = SEMVER_RE.match(version)
    if not match:
        raise ChartVersionerError(f"Only numeric semver versions are supported, got {version!r}")
    major, minor, patch = (int(part) for part in match.groups())
    if bump == "major":
        return f"{major + 1}.0.0"
    if bump == "minor":
        return f"{major}.{minor + 1}.0"
    if bump == "patch":
        return f"{major}.{minor}.{patch + 1}"
    raise ChartVersionerError(f"Unknown bump type {bump!r}")


def commit_messages_for_chart(base, head, chart, charts_dir, cwd):
    output = git(["log", "--format=%B%x00", f"{base}..{head}", "--", f"{charts_dir}/{chart}"], cwd)
    return [message.strip() for message in output.split("\x00") if message.strip()]


def bump_from_messages(messages):
    selected = None
    for message in messages:
        first_line = message.splitlines()[0] if message.splitlines() else ""
        type_match = TYPE_RE.match(first_line)
        if not type_match:
            continue

        commit_type = type_match.group("type")
        if commit_type not in ("feat", "fix"):
            continue

        if type_match.group("breaking"):
            selected = "major"
        elif commit_type == "feat":
            selected = max_bump(selected, "minor")
        elif commit_type == "fix":
            selected = max_bump(selected, "patch")

    return selected


def max_bump(current, candidate):
    if current is None:
        return candidate
    return current if BUMP_ORDER[current] >= BUMP_ORDER[candidate] else candidate


def replace_worktree_version(chart_path, next_version):
    chart_yaml = chart_path / "Chart.yaml"
    text = chart_yaml.read_text(encoding="utf-8")
    new_text, count = re.subn(r"^version:\s*.*$", f"version: {next_version}", text, count=1, flags=re.MULTILINE)
    if count != 1:
        raise ChartVersionerError(f"Could not update root version in {chart_yaml}")
    chart_yaml.write_text(new_text, encoding="utf-8")


def build_plan(base, head, charts_dir, cwd):
    files = changed_files(base, head, cwd)
    files_by_chart = {}
    for path in files:
        chart = chart_name_from_path(path, charts_dir)
        if not chart or not is_release_relevant(path):
            continue
        files_by_chart.setdefault(chart, []).append(path)

    chart_plans = []
    for chart in sorted(files_by_chart):
        chart_path = cwd / charts_dir / chart
        chart_yaml_path = f"{charts_dir}/{chart}/Chart.yaml"
        if not (chart_path / "Chart.yaml").exists():
            continue

        current_version = read_worktree_chart_version(chart_path)
        base_version = read_ref_chart_version(base, chart_yaml_path, cwd)
        if base_version is None:
            messages = commit_messages_for_chart(base, head, chart, charts_dir, cwd)
            bump = bump_from_messages(messages)
            if bump is None:
                continue
            chart_plans.append(
                {
                    "name": chart,
                    "path": f"{charts_dir}/{chart}",
                    "files": files_by_chart[chart],
                    "bump": "new",
                    "base_version": None,
                    "current_version": current_version,
                    "next_version": current_version,
                    "needs_update": False,
                }
            )
            continue

        messages = commit_messages_for_chart(base, head, chart, charts_dir, cwd)
        bump = bump_from_messages(messages)
        if bump is None:
            continue
        next_version = bump_version(base_version, bump)

        if current_version not in (base_version, next_version):
            raise ChartVersionerError(
                f"Chart {chart} has version {current_version}, expected {base_version} or {next_version}"
            )

        chart_plans.append(
            {
                "name": chart,
                "path": f"{charts_dir}/{chart}",
                "files": files_by_chart[chart],
                "bump": bump,
                "base_version": base_version,
                "current_version": current_version,
                "next_version": next_version,
                "needs_update": current_version != next_version,
            }
        )

    return {
        "base": base,
        "head": head,
        "changed_charts": [chart["name"] for chart in chart_plans],
        "charts": chart_plans,
    }


def write_github_output(path, plan):
    if not path:
        return
    changed = ",".join(plan["changed_charts"])
    lines = [
        f"has_changes={'true' if changed else 'false'}",
        f"changed_charts={changed}",
    ]
    with open(path, "a", encoding="utf-8") as handle:
        handle.write("\n".join(lines))
        handle.write("\n")


def write_output(path, plan):
    if not path:
        return
    Path(path).write_text(json.dumps(plan, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def cmd_plan(args):
    cwd = Path.cwd()
    base = resolve_base(args.base, args.head, cwd)
    plan = build_plan(base, args.head, args.charts_dir, cwd)
    write_output(args.output, plan)
    write_github_output(args.github_output, plan)
    print(json.dumps(plan, indent=2, sort_keys=True))


def cmd_write(args):
    cwd = Path.cwd()
    base = resolve_base(args.base, args.head, cwd)
    plan = build_plan(base, args.head, args.charts_dir, cwd)
    for chart in plan["charts"]:
        if chart["needs_update"]:
            replace_worktree_version(cwd / chart["path"], chart["next_version"])
            chart["updated"] = True
        else:
            chart["updated"] = False

    write_output(args.output, plan)
    write_github_output(args.github_output, plan)

    if not plan["charts"]:
        print("No changed charts detected.")
        return
    for chart in plan["charts"]:
        action = "updated" if chart["updated"] else "unchanged"
        print(f"{chart['name']}: {chart['base_version'] or 'new'} -> {chart['next_version']} ({chart['bump']}, {action})")


def cmd_check(args):
    cwd = Path.cwd()
    base = resolve_base(args.base, args.head, cwd)
    plan = build_plan(base, args.head, args.charts_dir, cwd)
    write_output(args.output, plan)
    write_github_output(args.github_output, plan)
    stale = [chart for chart in plan["charts"] if chart["needs_update"]]
    if stale:
        for chart in stale:
            print(
                f"{chart['name']} requires version {chart['next_version']} "
                f"({chart['bump']} from {chart['base_version']})",
                file=sys.stderr,
            )
        raise ChartVersionerError("Chart versions are not up to date")
    print(json.dumps(plan, indent=2, sort_keys=True))


def parser():
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--base", default=os.environ.get("CHART_VERSIONER_BASE", "HEAD~1"))
    common.add_argument("--head", default=os.environ.get("CHART_VERSIONER_HEAD", "HEAD"))
    common.add_argument("--charts-dir", default="charts")
    common.add_argument("--output")
    common.add_argument("--github-output")

    root = argparse.ArgumentParser(description="Plan and update Helm chart versions from changed chart commits.")
    subparsers = root.add_subparsers(dest="command", required=True)
    subparsers.add_parser("plan", parents=[common]).set_defaults(func=cmd_plan)
    subparsers.add_parser("write", parents=[common]).set_defaults(func=cmd_write)
    subparsers.add_parser("check", parents=[common]).set_defaults(func=cmd_check)
    return root


def main():
    args = parser().parse_args()
    try:
        args.func(args)
    except ChartVersionerError as error:
        print(f"error: {error}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
